# Database — PostgreSQL connection string from Neon (or any Postgres provider)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-secret-here"

# Email — Resend API key (resend.com, free tier)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Fantasy Stocks <noreply@yourdomain.com>"

# Cron endpoint protection secret — generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"
